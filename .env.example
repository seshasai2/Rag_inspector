# ============================================
# RAGInspector — Environment Configuration
# ============================================
# Copy to `.env` and fill in values. Never commit `.env`.
# Full secrets guide: SECURITY.md
# Cloud deploy: docs/DEPLOYMENT.md (Vercel + Render)
#
# Local interview: SECRET_KEY strongly recommended; rest can stay defaults.
# Free cloud API: SECRET_KEY, DATABASE_*, REDIS_URL, FRONTEND_URL,
#   ALLOWED_HOSTS, OPS_SHARED_TOKEN, REQUIRE_EMAIL_VERIFICATION=false
# Free cloud UI (Vercel): NEXT_PUBLIC_API_URL=https://<api-host>
# Optional (blank OK): HF_*, Razorpay, email, Google OAuth, Sentry, OTel
# Production template: .env.production.example
# ============================================

# ===== JWT / app =====
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-32-plus-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# ===== Frontend / hosts =====
# CORS Origin must match exactly (no trailing slash). See SECURITY.md.
# Cloud: https://your-app.vercel.app  |  API hosts: your-api.onrender.com
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# Email verification before login (unset = true only when ENVIRONMENT=production)
# Portfolio cloud without Resend/SMTP: set false
REQUIRE_EMAIL_VERIFICATION=false

# ===== Database (Settings) =====
# Defaults match docker-compose. Managed cloud may inject postgresql:// — auto-normalized.
DATABASE_URL=postgresql+asyncpg://raginspector:raginspector_secret@localhost:5432/raginspector
DATABASE_SYNC_URL=postgresql://raginspector:raginspector_secret@localhost:5432/raginspector

# ===== Database (docker-compose only) =====
POSTGRES_USER=raginspector
POSTGRES_PASSWORD=raginspector_secret
POSTGRES_DB=raginspector

# ===== Redis =====
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_PASSWORD=redis_secret
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5
# Optional short-TTL cache for dashboard aggregates — see docs/DASHBOARD_CACHE.md
DASHBOARD_METRICS_CACHE_ENABLED=true
DASHBOARD_METRICS_CACHE_TTL_SECONDS=30

# ===== AI analysis (OPTIONAL for interview demos) =====
# Prefer HF Inference API; otherwise local Ollama.
# Leave blank for interview: core NLI grounding uses local sentence-transformers.
# Seeded demo traces do not require HF/Ollama.
HF_API_TOKEN=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ===== ML models (Celery analysis) — see docs/COLD_START.md =====
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-small
# Interview / low-RAM hosts: set false (or use docker-compose.interview.yml).
# true shifts cold-start to worker boot; needs ~2–3GB free for models × concurrency.
WARM_ML_MODELS_ON_WORKER_START=true
ANALYSIS_SOFT_TIME_LIMIT_SECONDS=600
ANALYSIS_HARD_TIME_LIMIT_SECONDS=720
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
# Optional: protect /api/v1/ops/backlog|metrics|experimental with header X-Ops-Token
OPS_SHARED_TOKEN=

# ===== Billing (Razorpay) =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_PLAN_STARTER_MONTHLY=
RAZORPAY_PLAN_STARTER_ANNUAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=

# ===== Email =====
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@raginspector.com

# ===== Ops / support =====
SENTRY_DSN=
# Optional OpenTelemetry OTLP HTTP endpoint (requires opentelemetry-* extras)
OTEL_EXPORTER_OTLP_ENDPOINT=
SUPPORT_ADMIN_EMAILS=
BACKUP_RETENTION_DAYS=14
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# ===== Google SSO (Phase 10.13) =====
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/identity/sso/google/callback

# ===== Plan quotas (optional overrides) =====
FREE_TRACES_PER_MONTH=100
STARTER_TRACES_PER_MONTH=10000
PRO_TRACES_PER_MONTH=100000
ENTERPRISE_TRACES_PER_MONTH=999999999
