# Production / free-cloud template — copy into your secret manager / host env.
# Do not put real values in git. See SECURITY.md and docs/DEPLOYMENT.md.
#
# Compose self-host: hostnames `db` / `redis` (below).
# Render / Railway / Neon: paste managed URLs; the API normalizes
# postgresql:// → postgresql+asyncpg:// and adds SSL in ENVIRONMENT=production.

ENVIRONMENT=production
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Exact CORS origin (HTTPS, no trailing slash) — e.g. https://your-app.vercel.app
FRONTEND_URL=https://yourdomain.com
# Browser-facing API URL (set on Vercel as NEXT_PUBLIC_API_URL at build time)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# Comma-separated API hostnames only (no localhost) — e.g. raginspector-api.onrender.com
ALLOWED_HOSTS=api.yourdomain.com

# Portfolio demo without mail: false. Real production: true + Resend/SMTP.
REQUIRE_EMAIL_VERIFICATION=true

# --- Compose self-host ---
POSTGRES_USER=raginspector
POSTGRES_PASSWORD=
POSTGRES_DB=raginspector
DATABASE_URL=postgresql+asyncpg://raginspector:<password>@db:5432/raginspector
DATABASE_SYNC_URL=postgresql://raginspector:<password>@db:5432/raginspector

# --- Managed cloud example (Render) ---
# DATABASE_URL=postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com/raginspector
# DATABASE_SYNC_URL=postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com/raginspector

REDIS_PASSWORD=
REDIS_URL=redis://:<password>@redis:6379/0
# REDIS_URL=rediss://default:<password>@<upstash-host>:6379
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5
DASHBOARD_METRICS_CACHE_ENABLED=true
DASHBOARD_METRICS_CACHE_TTL_SECONDS=30

# Optional AI — leave blank for portfolio demos
HF_API_TOKEN=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-small
# false on free/small workers; true when RAM ≥ ~2–3GB per process
WARM_ML_MODELS_ON_WORKER_START=false
ANALYSIS_SOFT_TIME_LIMIT_SECONDS=600
ANALYSIS_HARD_TIME_LIMIT_SECONDS=720
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
OPS_SHARED_TOKEN=generate-a-strong-ops-token-min-16-chars

# Cloud web process
# PORT is injected by Render/Railway/Fly — do not hardcode in start scripts
UVICORN_WORKERS=1
RUN_MIGRATIONS=1

# Optional billing / email / ops
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_PLAN_STARTER_MONTHLY=
RAZORPAY_PLAN_STARTER_ANNUAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

SENTRY_DSN=
SUPPORT_ADMIN_EMAILS=
HTTP_PORT=80
BACKUP_RETENTION_DAYS=14

FREE_TRACES_PER_MONTH=100
STARTER_TRACES_PER_MONTH=10000
PRO_TRACES_PER_MONTH=100000
ENTERPRISE_TRACES_PER_MONTH=999999999
