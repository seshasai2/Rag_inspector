# Production template — copy into your secret manager / host env.
# Do not put real values in git. See SECURITY.md.

ENVIRONMENT=production
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
ALLOWED_HOSTS=api.yourdomain.com
REQUIRE_EMAIL_VERIFICATION=true

POSTGRES_USER=raginspector
POSTGRES_PASSWORD=
POSTGRES_DB=raginspector
DATABASE_URL=postgresql+asyncpg://raginspector:<password>@db:5432/raginspector
DATABASE_SYNC_URL=postgresql://raginspector:<password>@db:5432/raginspector

REDIS_PASSWORD=
REDIS_URL=redis://:<password>@redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5
DASHBOARD_METRICS_CACHE_ENABLED=true
DASHBOARD_METRICS_CACHE_TTL_SECONDS=30

HF_API_TOKEN=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-small
WARM_ML_MODELS_ON_WORKER_START=true
ANALYSIS_SOFT_TIME_LIMIT_SECONDS=600
ANALYSIS_HARD_TIME_LIMIT_SECONDS=720
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
OPS_SHARED_TOKEN=generate-a-strong-ops-token-min-16-chars

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_PLAN_STARTER_MONTHLY=
RAZORPAY_PLAN_STARTER_ANNUAL=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_ANNUAL=
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
RAZORPAY_PLAN_ENTERPRISE_ANNUAL=

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

SENTRY_DSN=
SUPPORT_ADMIN_EMAILS=
HTTP_PORT=80
BACKUP_RETENTION_DAYS=14

FREE_TRACES_PER_MONTH=100
STARTER_TRACES_PER_MONTH=10000
PRO_TRACES_PER_MONTH=100000
ENTERPRISE_TRACES_PER_MONTH=999999999
