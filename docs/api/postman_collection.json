{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "RAGInspector API",
    "description": "Postman Collection v2.1 for RAGInspector — auth, pipelines, ingest, queries, metrics, and health. Set collection variables baseUrl, accessToken, apiKey, pipelineId, and traceId after login/key creation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "pipelineId", "value": "" },
    { "key": "traceId", "value": "" },
    { "key": "demoEmail", "value": "demo@example.com" },
    { "key": "demoPassword", "value": "DemoPass123!" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/live"
          }
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Ops Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/ops/ready"
          }
        },
        {
          "name": "Ops Backlog",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/ops/backlog"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"name\": \"Demo User\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "}",
                  "if (json.refresh_token) {",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Pipelines",
      "item": [
        {
          "name": "List Pipelines",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/pipelines"
          }
        },
        {
          "name": "Create Pipeline",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('pipelineId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Pipeline\",\n  \"description\": \"Postman demo\",\n  \"queries_per_month\": 10000,\n  \"cost_per_wrong_answer_usd\": 5.0\n}"
            },
            "url": "{{baseUrl}}/api/v1/pipelines"
          }
        },
        {
          "name": "Get Pipeline",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}"
          }
        },
        {
          "name": "Pipeline Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}/stats"
          }
        }
      ]
    },
    {
      "name": "Keys",
      "item": [
        {
          "name": "Create API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.key) { pm.collectionVariables.set('apiKey', json.key); }",
                  "else if (json.secret) { pm.collectionVariables.set('apiKey', json.secret); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman SDK Key\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/keys"
          }
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/keys"
          }
        }
      ]
    },
    {
      "name": "Ingest",
      "item": [
        {
          "name": "Ingest Trace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.trace_id) { pm.collectionVariables.set('traceId', json.trace_id); }",
                  "else if (json.id) { pm.collectionVariables.set('traceId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pipeline_name\": \"Demo RAG Pipeline\",\n  \"query_text\": \"What is the refund policy?\",\n  \"answer_text\": \"Refunds are available within 30 days of purchase with a receipt.\",\n  \"retrieved_chunks\": [\n    {\n      \"chunk_id\": \"doc-policies-01\",\n      \"chunk_text\": \"Customers may request a full refund within 30 days of purchase when they provide a valid receipt.\",\n      \"similarity_score\": 0.91,\n      \"metadata\": { \"source\": \"policies.md\" }\n    },\n    {\n      \"chunk_id\": \"doc-shipping-01\",\n      \"chunk_text\": \"Shipping usually takes 3–5 business days.\",\n      \"similarity_score\": 0.41,\n      \"metadata\": { \"source\": \"shipping.md\" }\n    }\n  ],\n  \"retrieve_latency_ms\": 45,\n  \"generate_latency_ms\": 320\n}"
            },
            "url": "{{baseUrl}}/api/v1/ingest/trace"
          }
        }
      ]
    },
